generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  status         String    @default("PENDING") // PENDING, CONFIRMED
  
  // Checkout Info
  product        String?
  quantity       Int       @default(1)
  options        String[]
  totalPrice     Float?
  
  // Customer Info
  customerName   String?
  customerEmail  String?
  customerPhone  String?

  // Children Info (JSON to store varying arrays)
  childrenData   Json?
  
  // Conversion Tracking Info
  clientUserAgent String?
  clientIp        String?
  fbp             String?
  fbc             String?
}
